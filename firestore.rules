rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // For development/testing: Allow all reads and writes
    // WARNING: Make sure to change this before going to production
    match /{document=**} {
      allow read, write: if true;
    }
    
    // ---------------------------------------------------------
    // FUTURE PRODUCTION RULES (Uncomment these and delete above)
